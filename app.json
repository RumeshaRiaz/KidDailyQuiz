{
  "expo": {
    "name": "Kids Daily Quiz",
    "slug": "kidsquiz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#534AB7"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kidsquiz.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#534AB7"
      },
      "package": "com.kidsquiz.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-font",
        {
          "fonts": []
        }
      ],
      "./plugins/withAdMob"
    ],
    "extra": {
      "eas": {
        "projectId": "3bd11487-1c27-4be5-994d-750859714df5"
      }
    }
  }
}
